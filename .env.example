# ─── Neon PostgreSQL ──────────────────────────────────────────
# Get these from your Neon project dashboard → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_URL
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash or local) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Node.js API ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars

# ─── Google OAuth ─────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub OAuth ─────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Stripe ───────────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ─── AI Worker (internal) ────────────────────────────────────
AI_WORKER_URL=http://ai-worker:5000

# ─── Discord OAuth ────────────────────────────────────────────
# https://discord.com/developers/applications → OAuth2
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─── LinkedIn OAuth ───────────────────────────────────────────
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ─── Microsoft OAuth ──────────────────────────────────────────
# https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ─── Facebook OAuth ───────────────────────────────────────────
# https://developers.facebook.com/apps
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Twitter OAuth ────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard (OAuth 1.0a)
TWITTER_CONSUMER_KEY=your-twitter-consumer-key
TWITTER_CONSUMER_SECRET=your-twitter-consumer-secret

# ─── GitLab OAuth ─────────────────────────────────────────────
# https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=your-gitlab-client-id
GITLAB_CLIENT_SECRET=your-gitlab-client-secret

INTERNAL_API_SECRET=change-me-internal-secret

# ─── OpenAI (for LangChain agents) ───────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
