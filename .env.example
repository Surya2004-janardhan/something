# ═══════════════════════════════════════════════════════════════════════════════
#                    AGENTS PLATFORM — ENVIRONMENT TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values.
# Required: DATABASE_URL, REDIS_URL, JWT_SECRET, at least one LLM provider key
# 
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core Configuration ───────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=false

# ─── Database (Neon PostgreSQL recommended) ───────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
# Use "Pooled connection" for DATABASE_URL, "Direct connection" for DIRECT_URL
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=your-redis-host
REDIS_PORT=18818
REDIS_USER=default
REDIS_PASS=your-redis-password
REDIS_URL=redis://default:password@host:port
# Upstash: https://upstash.com (free tier available)
REDIS_URL=redis://localhost:6379/0

# ─── Security & Authentication ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars-minimum
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Internal API secret for service-to-service communication
INTERNAL_API_SECRET=your-internal-api-secret-32-chars-minimum

# ─── Server & Frontend ────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost/api

# ─── AI Worker (Internal Service) ─────────────────────────────────────────────
# Default: http://ai-worker:5000 (Docker Compose)
# Local dev: http://localhost:5000
AI_WORKER_URL=http://ai-worker:5000

# ═══════════════════════════════════════════════════════════════════════════════
#                        LLM PROVIDER API KEYS
# ═══════════════════════════════════════════════════════════════════════════════
# At least ONE provider key is required. Add as many as you want to use.

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Models: gpt-4-turbo, gpt-4, gpt-3.5-turbo
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── Anthropic Claude ───────────────────────────────────────────────────────
# Models: claude-3-opus, claude-3-sonnet, claude-3-haiku
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ──────────────────────────────────────────────────────────
# Models: gemini-pro, gemini-pro-vision
# Get key: https://makersuite.google.com/app/apikey (free tier available)
GOOGLE_API_KEY=AIzaSy...

# ─── Mistral AI ─────────────────────────────────────────────────────────────
# Models: mistral-large, mistral-medium, mistral-small
# Get key: https://console.mistral.ai
MISTRAL_API_KEY=...

# ─── Cohere ──────────────────────────────────────────────────────────────────
# Models: command, command-light
# Get key: https://dashboard.cohere.com
COHERE_API_KEY=...

# ─── Groq (Fast inference) ──────────────────────────────────────────────────
# Models: llama-3-70b, mixtral-8x7b, llama-2-70b
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# ─── Together AI (Multiple model providers) ─────────────────────────────────
# Models: 50+ open-source and premium models
# Get key: https://api.together.xyz
TOGETHER_API_KEY=...

# ─── Azure OpenAI ──────────────────────────────────────────────────────────
# Set both to use Azure as your OpenAI provider
# Azure Portal → Cognitive Services → Keys and Endpoint
AZURE_OPENAI_KEY=...
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_ID=...

# ─── OpenRouter (Aggregated model access) ──────────────────────────────────
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# ─── Ollama (Local LLM inference) ──────────────────────────────────────────
# Run locally: ollama pull llama2
# Endpoint: http://localhost:11434
OLLAMA_ENDPOINT=http://localhost:11434

# ─── Custom OpenAI-compatible endpoint ──────────────────────────────────────
# For any OpenAI-compatible API (vLLM, Text Generation WebUI, etc.)
CUSTOM_OPENAI_ENDPOINT=https://custom-api.example.com/v1
CUSTOM_OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════════════════════
#                        OAUTH PROVIDERS (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ─── GitHub OAuth ───────────────────────────────────────────────────────────
# Setup: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ─── Discord OAuth ──────────────────────────────────────────────────────────
# Setup: https://discord.com/developers/applications → OAuth2
DISCORD_CLIENT_ID=...
DISCORD_CLIENT_SECRET=...

# ─── Microsoft / Azure AD ────────────────────────────────────────────────────
# Setup: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...

# ─── LinkedIn OAuth ─────────────────────────────────────────────────────────
# Setup: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# ─── Facebook OAuth ─────────────────────────────────────────────────────────
# Setup: https://developers.facebook.com/apps
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# ─── Twitter OAuth / X ──────────────────────────────────────────────────────
# Setup: https://developer.twitter.com/en/portal/dashboard (v1.1 or OAuth 2.0)
TWITTER_CONSUMER_KEY=...
TWITTER_CONSUMER_SECRET=...

# ─── GitLab OAuth ───────────────────────────────────────────────────────────
# Setup: https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=...
GITLAB_CLIENT_SECRET=...

# ═══════════════════════════════════════════════════════════════════════════════
#                        PAYMENT & BILLING (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Setup: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...       # Test or Live secret key
STRIPE_PUBLISHABLE_KEY=pk_test_...  # Test or Live publishable key
STRIPE_WEBHOOK_SECRET=whsec_...     # Webhook secret for local testing

# Price IDs (find in Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ═══════════════════════════════════════════════════════════════════════════════
#                        EMAIL & NOTIFICATIONS (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── SendGrid ────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=...
SENDGRID_FROM_EMAIL=noreply@example.com

# ─── Resend (Modern email for developers) ──────────────────────────────────
RESEND_API_KEY=...

# ─── SMTP (Generic email provider) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...
SMTP_FROM_EMAIL=noreply@example.com

# ─── Slack Notifications ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ─── Webhook URL for external integrations ────────────────────────────────
WEBHOOK_BASE_URL=https://example.com/webhooks

# ═══════════════════════════════════════════════════════════════════════════════
#                        LOGGING & MONITORING (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Sentry (Error tracking) ──────────────────────────────────────────────
SENTRY_DSN=https://...@...sentry.io/...

# ─── Datadog (Monitoring & APM) ────────────────────────────────────────────
DATADOG_API_KEY=...
DATADOG_SITE=datadoghq.com

# ─── LogRocket (Session replay) ───────────────────────────────────────────
LOGROCKET_APP_ID=...

# ═══════════════════════════════════════════════════════════════════════════════
#                        ALLOWED HOSTS & CORS
# ═══════════════════════════════════════════════════════════════════════════════

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://example.com

# ═══════════════════════════════════════════════════════════════════════════════
# End of Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
