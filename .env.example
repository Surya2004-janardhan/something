# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_USER=agents
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agents

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=supersecretkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Service URLs (used by gateway / inter-service calls) ─────
AUTH_SERVICE_URL=http://auth:5001
AGENTS_SERVICE_URL=http://agents:5002
WORKFLOWS_SERVICE_URL=http://workflows:5003
NOTIFICATIONS_SERVICE_URL=http://notifications:5004

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
