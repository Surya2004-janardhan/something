# ─── Neon PostgreSQL ──────────────────────────────────────────
# Get these from your Neon project dashboard → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_URL
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash or local) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Node.js API ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars

# ─── Google OAuth ─────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub OAuth ─────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Stripe ───────────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# ─── Python AI Service (internal) ────────────────────────────
PYTHON_AI_URL=http://python-ai:5000

# ─── Internal service auth token ─────────────────────────────
INTERNAL_API_SECRET=change-me-internal-secret

# ─── OpenAI (for LangChain agents) ───────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
